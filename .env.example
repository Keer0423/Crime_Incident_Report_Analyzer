# Copy this file to .env and fill in your API key
# cp .env.example .env

# Required for PDF, Audio, and Text NLP modules (GPT-4o extraction + Whisper API)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use local Whisper model instead of Whisper API (no API key needed for audio)
# Run: python run_pipeline.py --audio call.mp3 --local-whisper
